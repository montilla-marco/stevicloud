{
  "name": "billing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/billing/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["typeScriptFiles"],
      "outputs": ["{workspaceRoot}/dist/apps/billing"],
      "options": {
        "command": "npm run build",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "npm run dev",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "npm test",
        "cwd": "{projectRoot}"
      }
    }
  },
  "implicitDependencies": ["shared-contracts", "oms"],
  "tags": ["scope:billing", "lang:typescript", "type:app", "bc:billing"]
}
